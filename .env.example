# PostgreSQL password (required)
POSTGRES_PASSWORD=changeme

# Gemini API key for Nova service (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated allowed CORS origins — no trailing slash
# For a shop on a local network, set this to your server's LAN IP, e.g.:
# ALLOWED_ORIGINS=http://192.168.1.100
ALLOWED_ORIGINS=http://localhost

# Host port to expose the frontend on (default: 80)
PORT=80
